# Hetzner device-test credentials
# Copy this file to scripts/.env.hetzner and fill in your values.
# .env.hetzner is gitignored — never commit it.

# Hetzner Cloud API token (Project → Security → API Tokens → Generate)
HCLOUD_TOKEN=your_token_here

# Name of the SSH public key registered in Hetzner Cloud
# (Project → Security → SSH Keys)
HCLOUD_SSH_KEY=your_key_name_here

# Path to the matching private key on this machine
TEST_SSH_KEY=~/.ssh/id_ed25519

# Optional overrides (uncomment to change defaults)
# SERVER_TYPE=cax31
# SERVER_LOCATION=nbg1
# SNAPSHOT_LABEL=role=glucodroid-device-test
# RESULTS_BASE=./device-test-results
